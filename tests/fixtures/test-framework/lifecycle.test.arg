case("lifecycle", (runner: Runner) => {
  runner.beforeAll((assert: Assert) => {
  });

  runner.beforeEach((assert: Assert) => {
  });

  runner.afterEach((assert: Assert) => {
  });

  runner.afterAll((assert: Assert) => {
  });

