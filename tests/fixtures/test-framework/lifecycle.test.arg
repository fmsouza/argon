case("lifecycle", function(runner: any): any {
  runner.beforeAll(function(): any {
  });

  runner.beforeEach(function(): any {
  });

  runner.afterEach(function(): any {
  });

  runner.afterAll(function(): any {
  });

  runner.when("first test", function(assert: any): any {
    assert.equals(1, 1);
  });

  runner.when("second test", function(assert: any): any {
    assert.equals(2, 2);
  });
});
