case("filters", function(runner: any): any {
  runner.when("this test runs", function(assert: any): any {
    assert.equals(1, 1);
  });

  runner.skip("this test is skipped", function(assert: any): any {
    assert.equals(99, 99);
  });

  runner.when("another passing test", function(assert: any): any {
    assert.equals("a", "a");
  });
});
