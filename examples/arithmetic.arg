// Arithmetic and comparison basics
const a: i32 = 21;
const b: i32 = 6;

const sum: i32 = a + b;
const diff: i32 = a - b;
const product: i32 = a * b;
const quotient: f64 = a / b;
const remainder: i32 = a % b;
const isGreater = a > b;

println(sum);
println(diff);
println(product);
println(quotient);
println(remainder);
println(isGreater);
