// Ownership and move semantics
struct Message {
    text: string;
}

function consume(msg: Message): string {
    return msg.text;
}

const m = Message { text: "owned-value" };
const consumed = consume(m);
console.log(consumed);

const a: i32 = 10;
const b: i32 = a;
console.log(a);
console.log(b);
