// Struct declarations and literals

from "std:io" import { println };

struct Point {
    x: f64;
    y: f64;
}

struct Color {
    r: u8;
    g: u8;
    b: u8;
}

const origin = Point { x: 0.0, y: 0.0 };
println(origin.x);
println(origin.y);

const red = Color { r: 255, g: 0, b: 0 };
println(red.r);
println(red.g);

function getX(p: &Point): f64 {
    return p.x;
}

println(getX(origin));
