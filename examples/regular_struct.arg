// Regular struct usage

from "std:io" import { println };

struct Point {
    x: f64;
    y: f64;
}

function midpoint(a: Point, b: Point): Point {
    return Point {
        x: (a.x + b.x) / 2.0,
        y: (a.y + b.y) / 2.0,
    };
}

const p1 = Point { x: 0.0, y: 0.0 };
const p2 = Point { x: 10.0, y: 20.0 };
const mid = midpoint(p1, p2);
println(mid.x);
