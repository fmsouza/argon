// Borrowing with shared references

from "std:io" import { println };

struct Point {
    x: f64;
    y: f64;
}

function readX(p: &Point): f64 {
    return p.x;
}

function translatedX(p: &Point, by: f64): Point {
    return Point { x: p.x + by, y: p.y };
}

const point = Point { x: 10.0, y: 20.0 };
const sharedRef = &point;

println(readX(sharedRef));
const shifted = translatedX(sharedRef, 5.0);
println(shifted.x);
