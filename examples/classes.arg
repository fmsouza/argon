// Classes, constructors, methods, and `new`
class Counter {
    value: i32;

    constructor(initial: i32) {
        this.value = initial;
    }

    increment(): void with &mut this {
        this.value = this.value + 1;
    }

    getValue(): i32 with &this {
        return this.value;
    }
}

const counter = new Counter(10);
counter.increment();
counter.increment();
console.log(counter.getValue());
