// try/catch/finally
function guardedDivide(a: i32, b: i32): i32 {
    try {
        if (b == 0) {
            throw 1;
        }
        return a / b;
    } catch (err) {
        const captured = err;
        println(captured);
        return 0;
    } finally {
        const cleanupDone = true;
        println(cleanupDone);
    }

    return 0;
}

println(guardedDivide(10, 2));
println(guardedDivide(10, 0));
