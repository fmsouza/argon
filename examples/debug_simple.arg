// Result-based error handling

from "std:io" import { println };

function guardedDivide(a: i32, b: i32): Result<i32, i32> {
    if (b == 0) {
        return Err { error: 1 };
    }

    return Ok { value: a / b };
}

const first = guardedDivide(10, 2);
match (first) {
    Ok(value) => println(value),
    Err(error) => println(error),
}

const second = guardedDivide(10, 0);
match (second) {
    Ok(value) => println(value),
    Err(error) => println(error),
}
