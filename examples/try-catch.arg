// Structured error handling
function recoverOrDefault(flag: bool): i32 {
    try {
        if (flag) {
            throw 7;
        }
        return 1;
    } catch (err) {
        const captured = err;
        console.log(captured);
        return 0;
    } finally {
        const cleaned = true;
        console.log(cleaned);
    }

    return 0;
}

console.log(recoverOrDefault(false));
console.log(recoverOrDefault(true));
