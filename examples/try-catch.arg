// Structured error handling

from "std:io" import { println };

function recoverOrDefault(flag: bool): i32 {
    try {
        if (flag) {
            throw 7;
        }
        return 1;
    } catch (err) {
        const captured = err;
        println(captured);
        return 0;
    } finally {
        const cleaned = true;
        println(cleaned);
    }

    return 0;
}

println(recoverOrDefault(false));
println(recoverOrDefault(true));
