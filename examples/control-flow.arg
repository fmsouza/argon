// if/else, while, for, switch, and loop

from "std:io" import { println };

const x: i32 = 4;

if (x > 3) {
    println(1);
} else {
    println(0);
}

let whileSum: i32 = 0;
let i: i32 = 0;
while (i < 3) {
    whileSum = whileSum + i;
    i = i + 1;
}
println(whileSum);

let forSum: i32 = 0;
for (let j = 0; j < 4; j = j + 1) {
    if (j == 2) {
        continue;
    }
    forSum = forSum + j;
}
println(forSum);

let chosen: i32 = 0;
switch (x) {
    case 1:
        chosen = 10;
        break;
    case 4:
        chosen = 40;
        break;
    default:
        chosen = -1;
}
println(chosen);

let loopCount: i32 = 0;
loop {
    loopCount = loopCount + 1;
    if (loopCount >= 2) {
        break;
    }
}
println(loopCount);
